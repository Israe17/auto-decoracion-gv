rules_version = '2';

// Catalogo publico de solo lectura; escritura reservada al admin autenticado.
// Publicar en Firebase Console > Firestore Database > Rules.
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /promos/{promoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
