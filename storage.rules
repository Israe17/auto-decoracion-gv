rules_version = '2';

// Imagenes del catalogo: lectura publica, subida solo para el admin autenticado.
// Publicar en Firebase Console > Storage > Rules.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
